# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/docs/test-results/*
/docs/test-plan/*
/docs/test-system/*

# next.js
/.next/
/out/

# production
/build
.claude/*
.claude/settings.local.json

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.local
.env.vercel.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
