# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# tools / IDE
/.idea
/.pytest_cache

# Python 字节码（不提交编译缓存）
__pycache__/
*.pyc
*.pyo

# testing
/coverage
/docs/test-system/*
/docs/skills/*
/docs/test-trisql/*
/docs/test-plan/*
/docs/test-result/*
!/docs/test-result/T1-*.md
!/docs/test-result/T2-*.md
!/docs/test-result/T3-*.md
!/docs/test-plan/T1-*.md
!/docs/test-plan/T2-*.md
!/docs/test-plan/T3-*.md

# next.js
/.next/
/out/

# production
/build
.claude/*
.claude/settings.local.json

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.local
.env.vercel.local

# vercel
.vercel

# supabase CLI 本地状态（不含迁移文件，仅排除自动生成的临时目录）
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts
